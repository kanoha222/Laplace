# Laplace 环境配置示例
# 复制此文件为 .env 并填入真实 Key

# === LLM 多提供商配置 ===
# 提供商降级链（按优先级排列，逗号分隔）
LLM_PROVIDERS=obao

# 提供商: obao
LLM_OBAO_URL=https://x.obao.cloud/v1
LLM_OBAO_KEY=your-obao-api-key-here
LLM_OBAO_MODELS=claude-sonnet-4-6,Deepseek-V4-Flash,gpt-5.4

# 提供商: openai（取消注释并在 LLM_PROVIDERS 中添加 openai 即可启用）
# LLM_OPENAI_URL=https://api.openai.com/v1
# LLM_OPENAI_KEY=your-openai-api-key-here
# LLM_OPENAI_MODELS=gpt-4o,gpt-4o-mini

# 向后兼容旧格式（未配置 LLM_PROVIDERS 时自动回退）
# LLM_BASE_URL=https://x.obao.cloud/v1
# LLM_API_KEY=your-api-key-here
# LLM_MODEL=claude-sonnet-4-6
# LLM_FALLBACK_MODELS=Deepseek-V4-Flash,gpt-5.4

# === CORS 白名单 ===
# CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# === 速率限制 ===
# RATE_LIMIT_PER_MINUTE=10
# RATE_LIMIT_GLOBAL_PER_MINUTE=100

# === Chaldea 源码路径 ===
# CHALDEA_SRC_PATH=/path/to/your/chaldea
